@startuml fig3_decoder_resolver
!include _kipo_style.iuml

title Fig. 3 — 디코더 (220) 및 리졸버 (250) 의 동작 흐름

start
:**S200** — 페이로드 입력 (QR 스캐너 인터페이스 210)\npayload (단일 페이로드 문자열, 10)\naccess_level ∈ {제1, 제2, 제3 출력 수준}\npublic_key (선택);

partition "디코더 (220)" {
  if (**S201** — 구획자 (12) 가\npayload 내에 존재하는가?) then (no)
    :return\n(payload as Layer A, empty Layer B/C);
    note right
      단순 모드 처리
      (청구항 5)
    end note
  else (yes)
    :**S202** — split(DELIMITER, max=1)\n→ Layer A (11), 트레일러 (13);
    :**S203** — 트레일러 디코딩 + 헤더 파싱\nframe = base64.b64decode(trailer)\n(version, b_len, c_len) =\n  unpack(">BHH", frame[:5])  ← 이진 헤더 (14)\n버전·길이 정합성 검증\nLayer B (15) = frame[5 : 5+b_len]\nLayer C (16) = frame[5+b_len :\n               5+b_len+c_len];
  endif
}

partition "리졸버 (250)" {
  :**S204** — 출력 수준 정규화\n(미지의 access_level → 제1 출력 수준);

  if (**S205** — decode 성공?) then (no)
    #white:**S207** — safe-fallback\nLayer A 만 반환;
    detach
  else (yes)
  endif

  switch (**S206** — 출력 수준 분기)
  case (제1\n(public))
    :return (Layer A,\n  vr=public);
    stop
  case (제2\n(authenticated))
    :return (Layer A, Layer B,\n  vr=unverified);
    stop
  case (제3\n(verified))
    if (public_key 존재?) then (no)
      #white:**S207** — safe-fallback;
      detach
    else (yes)
      :**검증부 (240)** —\nsigning_message 재구성\n(A, B 로부터, §8.1.1)\nverify_signature(pk,\n  signing_message, Layer C);
      if (서명 valid?) then (yes)
        :return (Layer A, Layer B,\n  vr=valid,\n  signature=optional\n   (diagnostic));
      else (no)
        #white:**S207** — safe-fallback;
        detach
      endif
    endif
  endswitch
}

:**S208** — 반환 출력 인터페이스 (260)\n사용자 또는 후속 응용 모듈로 결과 전달;
stop

@enduml
