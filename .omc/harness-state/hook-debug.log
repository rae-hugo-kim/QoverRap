[2026-04-23T09:17:49.384Z] acceptance-gate: Command: set -a && source .env && set +a && python3 <<'PY'
import os, base64, urllib.request, urllib.parse, json, time

k, s = os.environ['EPO_OPS_KEY'], os.environ['EPO_OPS_SECRET']
a = base64.b64encode(f'{k}:{s}'.encode()).decode()
tok = json.loads(urllib.request.urlopen(urllib.request.Request(
    'https://ops.epo.org/3.2/auth/accesstoken',
    data=urllib.parse.urlencode({'grant_type':'client_credentials'}).encode(),
    headers={'Authorization':f'Basic {a}','Content-Type':'application/x-www-form-urlencoded'}),
    timeout=15).read())['access_token']

queries = [
    ('apple-3d-auth', 'pa=("apple inc" OR "apple computer") AND ti,ab=(authentication AND (3D OR three-dimensional OR depth OR spatial))', '1-25'),
    ('apple-qr-auth', 'pa=("apple inc") AND ti,ab=(QR AND authentication)', '1-25'),
    ('apple-wearable-auth', 'pa=("apple inc") AND ti,ab=(wearable AND (image OR visual) AND authentication)', '1-25'),
    ('3d-object-auth', 'ti,ab=("3D" AND "object" AND "authentication" AND ("wearable" OR "watch"))', '1-25'),
]

for label, cql, rng in queries:
    q = urllib.parse.quote(cql)
    req = urllib.request.Request(
        f'https://ops.epo.org/3.2/rest-services/published-data/search?q={q}&Range={rng}',
        headers={'Authorization': f'Bearer {tok}', 'Accept': 'application/json'})
    try:
        r = urllib.request.urlopen(req, timeout=30)
        body = json.loads(r.read())
        biblio = body.get('ops:world-patent-data',{}).get('ops:biblio-search',{})
        total = biblio.get('@total-result-count')
        refs = biblio.get('ops:search-result',{}).get('ops:publication-reference',[])
        if isinstance(refs, dict): refs = [refs]
        pubs = []
        for ref in refs[:10]:
            docs = ref.get('document-id',[])
            if isinstance(docs, dict): docs = [docs]
            for d in docs:
                if d.get('@document-id-type')=='docdb':
                    pubs.append(f"{(d.get('country') or {}).get('$','')}{(d.get('doc-number') or {}).get('$','')}{(d.get('kind') or {}).get('$','')}")
                    break
        print(f"\n=== {label} ===")
        print(f"  CQL: {cql[:90]}")
        print(f"  total={total} top10={pubs}")
    except urllib.error.HTTPError as e:
        code = e.code
        msg = e.read().decode()[:200]
        print(f"\n=== {label} ===")
        print(f"  CQL: {cql[:90]}")
        print(f"  HTTP {code}: {msg}")
    time.sleep(5)
PY
