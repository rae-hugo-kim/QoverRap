[2026-04-16T05:48:24.674Z] acceptance-gate: Command: .venv/bin/python -c "
import random
from qoverwrap.crypto import generate_keypair, sign_layers
from qoverwrap.encoder import encode_layers
import qrcode
from pyzbar.pyzbar import decode as pyzbar_decode

priv, pub = generate_keypair()
layer_a = 'https://qoverwrap.example.com/v1/card?id=abc123'
layer_b = b'{\"issuer\":\"QoverwRap\"}'
layer_c = sign_layers(priv, layer_a, layer_b)
payload_str = encode_layers(layer_a, layer_b, layer_c)
print('payload_str[:80]:', repr(payload_str[:80]))
print('layer_a:', repr(layer_a))

qr = qrcode.QRCode(version=None, error_correction=qrcode.constants.ERROR_CORRECT_M, box_size=10, border=4)
qr.add_data(payload_str)
qr.make(fit=True)
img = qr.make_image(fill_color='black', back_color='white')
print('img type:', type(img))
print('img mode:', img.mode if hasattr(img, 'mode') else 'N/A')

decoded = pyzbar_decode(img)
print('pyzbar decoded count:', len(decoded))
if decoded:
    print('decoded data[:80]:', repr(decoded[0].data[:80]))
    text = decoded[0].data.decode('utf-8', errors='replace')
    print('starts with layer_a:', text.startswith(layer_a))
else:
    print('ERROR: pyzbar returned empty list')
    # Try converting to PIL Image
    from PIL import Image
    pil_img = img.convert('RGB') if hasattr(img, 'convert') else img
    print('pil img type:', type(pil_img))
    decoded2 = pyzbar_decode(pil_img)
    print('decoded2 count:', len(decoded2))
"

