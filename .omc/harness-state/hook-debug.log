import os, base64, urllib.request, urllib.parse, json, time
k, s = os.environ['EPO_OPS_KEY'], os.environ['EPO_OPS_SECRET']
a = base64.b64encode(f'{k}:{s}'.encode()).decode()
tok = json.loads(urllib.request.urlopen(urllib.request.Request(
    'https://ops.epo.org/3.2/auth/accesstoken',
    data=urllib.parse.urlencode({'grant_type':'client_credentials'}).encode(),
    headers={'Authorization':f'Basic {a}','Content-Type':'application/x-www-form-urlencoded'}),
    timeout=15).read())['access_token']

def fetch(docid):
    url = f'https://ops.epo.org/3.2/rest-services/published-data/publication/docdb/{docid}/biblio,abstract'
    req = urllib.request.Request(url, headers={'Authorization':f'Bearer {tok}','Accept':'application/json'})
    try:
        body = json.loads(urllib.request.urlopen(req, timeout=30).read())
        open(f"docs/research/epo-triage-{docid.replace('.','-')}.json",'w').write(json.dumps(body, ensure_ascii=False, indent=2))
        def walk(o, keys):
            if isinstance(o, dict):
                for k2, v in o.items():
                    if k2 in keys: yield k2, v
                    yield from walk(v, keys)
            elif isinstance(o, list):
                for i in o: yield from walk(i, keys)
        print(f"\n--- {docid} ---")
        for key, v in walk(body, ['invention-title','abstract','applicant','inventor']):
            if key in ('invention-title','abstract'):
                items = v if isinstance(v, list) else [v]
                for it in items:
                    if isinstance(it, dict):
                        lang = it.get('@lang','?')
                        if key == 'invention-title':
                            print(f"  TITLE [{lang}]: {it.get('$','')}")
                        else:
                            p = it.get('p')
                            if isinstance(p, dict): text = p.get('$','')
                            elif isinstance(p, list): text = ' '.join(x.get('$','') if isinstance(x, dict) else str(x) for x in p)
                            else: text = str(p)
                            print(f"  ABSTRACT [{lang}]: {text[:600]}")
            elif key == 'applicant':
                items = v if isinstance(v, list) else [v]
                names = set()
                for it in items:
                    if isinstance(it, dict):
                        an = it.get('applicant-name')
                        if isinstance(an, dict): names.add(str(an.get('name',{}).get('$','?') if isinstance(an.get('name'), dict) else an.get('name','?')))
                if names: print(f"  APPLICANTS: {names}")
    except urllib.error.HTTPError as e:
        print(f"  HTTP {e.code}: {e.read().decode()[:200]}")

