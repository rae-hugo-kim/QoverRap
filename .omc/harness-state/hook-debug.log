import json
data = json.load(open('docs/research/kipris-results.json', encoding='utf-8'))

print("=== SUMMARY ===")
for r in data:
    print(f"  [{r['keyword']}] total={r.get('totalCount')}  sample_items={len(r.get('items',[]))}")

print("\n=== QR코드 오버래핑 (가장 좁은 키워드, 32건) ===")
overlap = next(r for r in data if r['keyword'] == 'QR코드 오버래핑')
for i, it in enumerate(overlap['items'][:15], 1):
    print(f"\n{i}. {it.get('inventionTitle')}")
    print(f"   출원: {it.get('applicationNumber')} / {it.get('applicationDate')}")
    print(f"   등록: {it.get('registerNumber')} ({it.get('registerStatus')})")
    print(f"   IPC: {it.get('ipcNumber')}")
    print(f"   출원인: {it.get('applicantName')}")
    ab = it.get('abstract') or ''
    print(f"   초록: {ab[:200]}")
EOF
