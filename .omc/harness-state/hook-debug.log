import os, base64, urllib.request, urllib.parse, json
key = os.environ['EPO_OPS_KEY']
secret = os.environ['EPO_OPS_SECRET']
auth = base64.b64encode(f'{key}:{secret}'.encode()).decode()
data = urllib.parse.urlencode({'grant_type': 'client_credentials'}).encode()
req = urllib.request.Request(
    'https://ops.epo.org/3.2/auth/accesstoken',
    data=data,
    headers={'Authorization': f'Basic {auth}', 'Content-Type': 'application/x-www-form-urlencoded'},
)
try:
    with urllib.request.urlopen(req, timeout=15) as r:
        tok = json.loads(r.read())
        print('AUTH OK')
        print('token_type:', tok.get('token_type'))
        print('expires_in:', tok.get('expires_in'))
        print('access_token_len:', len(tok.get('access_token','')))
except urllib.error.HTTPError as e:
    print('HTTP', e.code, e.reason)
    print(e.read().decode()[:500])
except Exception as e:
    print('ERR', type(e).__name__, e)
"

