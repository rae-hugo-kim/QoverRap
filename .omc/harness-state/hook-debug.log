import os, base64, urllib.request, urllib.parse, json, time, re
k, s = os.environ['EPO_OPS_KEY'], os.environ['EPO_OPS_SECRET']
a = base64.b64encode(f'{k}:{s}'.encode()).decode()
tok = json.loads(urllib.request.urlopen(urllib.request.Request(
    'https://ops.epo.org/3.2/auth/accesstoken',
    data=urllib.parse.urlencode({'grant_type':'client_credentials'}).encode(),
    headers={'Authorization':f'Basic {a}','Content-Type':'application/x-www-form-urlencoded'}),
    timeout=15).read())['access_token']

# 1. Fetch abstract for CN111224771A
print("=== 1. CN111224771A biblio+abstract ===")
url = 'https://ops.epo.org/3.2/rest-services/published-data/publication/docdb/CN.111224771.A/biblio,abstract'
req = urllib.request.Request(url, headers={'Authorization': f'Bearer {tok}', 'Accept': 'application/json'})
try:
    body = json.loads(urllib.request.urlopen(req, timeout=30).read())
    out = json.dumps(body, ensure_ascii=False, indent=2)
    open('docs/research/epo-triage-CN111224771A.json','w').write(out)
    # Pull title + abstract
    def walk(o, keys):
        if isinstance(o, dict):
            for k2, v in o.items():
                if k2 in keys:
                    yield k2, v
                yield from walk(v, keys)
        elif isinstance(o, list):
            for i in o: yield from walk(i, keys)
    titles, abs_texts = [], []
    for key, v in walk(body, ['invention-title','abstract']):
        if key == 'invention-title':
            t = v if isinstance(v, list) else [v]
            for tt in t:
                lang = tt.get('@lang','?') if isinstance(tt, dict) else '?'
                text = tt.get('$') if isinstance(tt, dict) else str(tt)
                titles.append(f'[{lang}] {text}')
        elif key == 'abstract':
            a_list = v if isinstance(v, list) else [v]
            for av in a_list:
                if isinstance(av, dict):
                    lang = av.get('@lang','?')
                    p = av.get('p')
                    if isinstance(p, dict): text = p.get('$','')
                    elif isinstance(p, list): text = ' '.join(x.get('$','') if isinstance(x, dict) else str(x) for x in p)
                    else: text = str(p)
                    abs_texts.append(f'[{lang}] {text[:800]}')
    print("TITLES:")
    for t in titles: print(f"  {t}")
    print("\nABSTRACT:")
    for a2 in abs_texts: print(f"  {a2}")
except urllib.error.HTTPError as e:
    print(f"HTTP {e.code}: {e.read().decode()[:300]}")
time.sleep(5)

# 2. Sanity: EPO has CN QR patents at all?
print("\n=== 2. Sanity check: CN QR volume ===")
q = urllib.parse.quote('ti=(QR) AND cpc=G06K19/06')
req = urllib.request.Request(f'https://ops.epo.org/3.2/rest-services/published-data/search?q={q}&Range=1-1',
    headers={'Authorization': f'Bearer {tok}','Accept':'application/json'})
try:
    b = json.loads(urllib.request.urlopen(req, timeout=20).read())
    total = b.get('ops:world-patent-data', {}).get('ops:biblio-search', {}).get('@total-result-count')
    print(f"  ti=QR AND cpc=G06K19/06 → total={total}")
except urllib.error.HTTPError as e:
    print(f"  HTTP {e.code}: {e.read().decode()[:200]}")
time.sleep(5)

# 3. CN multilayer QR broader
print("\n=== 3. CN multilayer/hierarchical QR broader ===")
for cql in [
    'ti,ab=(QR AND (hierarchical OR tiered OR nested OR "nested code"))',
    'ti,ab=("multi-layer QR" OR "multi level QR" OR "multilayer QR")',
    'ti,ab=(QR AND (authenticity OR authentication OR tamper))',
]:
    q2 = urllib.parse.quote(cql)
    req = urllib.request.Request(f'https://ops.epo.org/3.2/rest-services/published-data/search?q={q2}&Range=1-5',
        headers={'Authorization':f'Bearer {tok}','Accept':'application/json'})
    try:
        b = json.loads(urllib.request.urlopen(req, timeout=20).read())
        biblio = b.get('ops:world-patent-data',{}).get('ops:biblio-search',{})
        total = biblio.get('@total-result-count')
        refs = biblio.get('ops:search-result',{}).get('ops:publication-reference',[])
        if isinstance(refs, dict): refs = [refs]
        cn_hits = []
        for ref in refs:
            docs = ref.get('document-id',[])
            if isinstance(docs, dict): docs = [docs]
            for d in docs:
                if d.get('@document-id-type')=='docdb' and (d.get('country') or {}).get('$') == 'CN':
                    cn_hits.append(f"CN{(d.get('doc-number') or {}).get('$','?')}{(d.get('kind') or {}).get('$','')}")
                    break
        print(f"  {cql[:65]}")
        print(f"    total={total} first5_CN_hits={cn_hits}")
    except urllib.error.HTTPError as e:
        print(f"  {cql[:65]} → HTTP {e.code}")
    time.sleep(5)
PY
