[2026-04-17T06:50:56.250Z] acceptance-gate: Command: python3 << 'EOF'
import json
data = json.load(open('docs/research/kipris-results-title.json', encoding='utf-8'))

# Dedupe by applicationNumber across all keywords
seen = {}
for r in data:
    kw = r['keyword']
    for it in r.get('items', []):
        an = it.get('applicationNumber')
        if not an: continue
        if an not in seen:
            seen[an] = {**it, "_matched": []}
        seen[an]["_matched"].append(kw)

print(f"TOTAL UNIQUE: {len(seen)}\n")

# Print high-priority (excluding QR 인증 only matches)
priority = [v for v in seen.values() if set(v['_matched']) - {'QR 인증'}]
priority.sort(key=lambda x: x.get('applicationDate') or '', reverse=True)

print(f"=== HIGH-PRIORITY ({len(priority)}) — excluding broad 'QR 인증' only ===\n")
for i, it in enumerate(priority, 1):
    print(f"{i}. {it.get('inventionTitle')}")
    print(f"   출원: {it.get('applicationNumber')} ({it.get('applicationDate')}) / 등록: {it.get('registerNumber')} [{it.get('registerStatus')}]")
    print(f"   출원인: {it.get('applicantName')}")
    print(f"   매칭: {it['_matched']}")
    print(f"   IPC: {it.get('ipcNumber')}")
    ab = (it.get('abstract') or '').replace('\n',' ')[:300]
    print(f"   초록: {ab}")
    print()
EOF
